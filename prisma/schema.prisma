// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  uid       String    @id
  type      CardType  @default(UNKNOWN)
  name      String
  comment   String
  sectors   CardSector[]
}

enum CardType {
  UNKNOWN
  HAPPY_CASH
  EASY_CARD
  I_PASS
}

model CardSector {
  card      Card?   @relation(fields: [cardUid], references: [uid])
  cardUid   String
  index     Int
  keyA      String?
  keyB      String?
  @@id([cardUid, index])
}
